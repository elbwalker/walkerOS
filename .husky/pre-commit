STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|tsx|json|css|md)$' || true)
[ -z "$STAGED" ] && exit 0

# Auto-format staged files in place. No git operations = no lock contention.
echo "$STAGED" | xargs npx prettier --write --log-level warn

# Check if prettier changed anything
if ! echo "$STAGED" | xargs git diff --quiet --; then
  echo ""
  echo "Files were auto-formatted by prettier."
  echo "Please re-stage and commit again:"
  echo "$STAGED" | xargs git diff --name-only -- | sed 's/^/  /'
  echo ""
  exit 1
fi

exit 0
