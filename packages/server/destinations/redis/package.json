{
  "name": "@walkeros/server-destination-redis",
  "description": "Redis Streams server destination for walkerOS (ioredis, XADD, pipeline batching)",
  "version": "3.4.2",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.mjs",
      "require": "./dist/dev.js"
    },
    "./walkerOS.json": "./dist/walkerOS.json",
    "./examples": {
      "types": "./dist/examples/index.d.ts",
      "import": "./dist/examples/index.mjs",
      "require": "./dist/examples/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup --silent",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "jest --watchAll --colors",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.ts*\"",
    "test": "jest",
    "update": "npx npm-check-updates -u && npm update"
  },
  "dependencies": {
    "ioredis": "^5.10.0",
    "@walkeros/core": "3.4.2",
    "@walkeros/server-core": "3.4.2"
  },
  "devDependencies": {
    "@walkeros/collector": "3.4.2"
  },
  "repository": {
    "url": "git+https://github.com/elbwalker/walkerOS.git",
    "directory": "packages/server/destinations/redis"
  },
  "author": "elbwalker <hello@elbwalker.com>",
  "homepage": "https://github.com/elbwalker/walkerOS#readme",
  "bugs": {
    "url": "https://github.com/elbwalker/walkerOS/issues"
  },
  "walkerOS": {
    "type": "destination",
    "platform": [
      "server"
    ],
    "docs": "https://www.walkeros.io/docs/destinations/server/redis"
  },
  "keywords": [
    "walkerOS",
    "walkerOS-destination",
    "destination",
    "server",
    "redis",
    "redis-streams",
    "ioredis",
    "event-streaming"
  ],
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/elbwalker"
    }
  ]
}
