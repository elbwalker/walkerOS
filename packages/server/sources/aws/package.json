{
  "name": "@walkeros/server-source-aws",
  "description": "AWS server sources for walkerOS (Lambda, API Gateway, Function URLs)",
  "version": "4.1.0",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup --silent",
    "clean": "rm -rf .turbo && rm -rf dist",
    "dev": "jest --watchAll --colors",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.ts*\"",
    "test": "jest",
    "update": "npx npm-check-updates -u && npm update"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.952.0",
    "@aws-sdk/client-sns": "^3.952.0",
    "@walkeros/core": "4.1.0"
  },
  "peerDependencies": {
    "@types/aws-lambda": "^8.10.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.159",
    "@walkeros/collector": "4.1.0"
  },
  "repository": {
    "url": "git+https://github.com/elbwalker/walkerOS.git",
    "directory": "packages/server/sources/aws"
  },
  "author": "elbwalker <hello@elbwalker.com>",
  "homepage": "https://github.com/elbwalker/walkerOS#readme",
  "bugs": {
    "url": "https://github.com/elbwalker/walkerOS/issues"
  },
  "walkerOS": {
    "type": "source",
    "platform": [
      "server"
    ],
    "docs": "https://www.walkeros.io/docs/sources/server/aws",
    "exports": {
      "sourceLambda": "AWS Lambda event source",
      "sourceSqs": "AWS SQS event source (long-running poll-and-forward, with setup lifecycle)"
    }
  },
  "keywords": [
    "walkerOS",
    "walkerOS-source",
    "source",
    "server",
    "aws",
    "lambda",
    "api gateway",
    "analytics"
  ],
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/elbwalker"
    }
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./sqs": {
      "types": "./dist/sqs/index.d.ts",
      "import": "./dist/sqs/index.mjs",
      "require": "./dist/sqs/index.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.mjs",
      "require": "./dist/dev.js"
    },
    "./walkerOS.json": "./dist/walkerOS.json"
  }
}
