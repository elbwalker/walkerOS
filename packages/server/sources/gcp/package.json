{
  "name": "@walkeros/server-source-gcp",
  "description": "Google Cloud Platform server sources for walkerOS (Cloud Functions, Pub/Sub)",
  "version": "4.1.0",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup --silent",
    "clean": "rm -rf .turbo && rm -rf dist",
    "dev": "jest --watchAll --colors",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.ts*\"",
    "test": "jest",
    "update": "npx npm-check-updates -u && npm update"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@walkeros/collector": "4.1.0",
    "@walkeros/core": "4.1.0"
  },
  "peerDependencies": {
    "@google-cloud/functions-framework": "^3.0.0"
  },
  "devDependencies": {},
  "repository": {
    "url": "git+https://github.com/elbwalker/walkerOS.git",
    "directory": "packages/server/sources/gcp"
  },
  "author": "elbwalker <hello@elbwalker.com>",
  "homepage": "https://github.com/elbwalker/walkerOS#readme",
  "bugs": {
    "url": "https://github.com/elbwalker/walkerOS/issues"
  },
  "walkerOS": {
    "type": "source",
    "platform": [
      "server"
    ],
    "docs": "https://www.walkeros.io/docs/sources/server/gcp",
    "exports": {
      "sourceCloudFunction": "GCP Cloud Function event source",
      "sourcePubSubPull": "Pub/Sub pull subscriber (long-running)",
      "sourcePubSubPush": "Pub/Sub push webhook handler (HTTP POST)"
    },
    "bundle": {
      "external": [
        "@google-cloud/pubsub"
      ]
    }
  },
  "keywords": [
    "walkerOS",
    "walkerOS-source",
    "source",
    "server",
    "gcp",
    "cloud functions",
    "pubsub",
    "pub-sub",
    "messaging",
    "analytics"
  ],
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/elbwalker"
    }
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.mjs",
      "require": "./dist/dev.js"
    },
    "./walkerOS.json": "./dist/walkerOS.json"
  }
}
