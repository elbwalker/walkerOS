{
  "name": "@walkeros/server-transformer-bot",
  "description": "Server-side bot and AI-agent detection transformer for walkerOS",
  "version": "4.3.0",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./walkerOS.json": "./dist/walkerOS.json"
  },
  "files": [
    "dist/**",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup --silent",
    "clean": "rm -rf .turbo && rm -rf dist",
    "dev": "jest --watchAll --colors",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.ts*\"",
    "test": "jest",
    "update": "npx npm-check-updates -u && npm update"
  },
  "dependencies": {
    "@walkeros/core": "4.3.0",
    "isbot": "^5.1.39"
  },
  "repository": {
    "url": "git+https://github.com/elbwalker/walkerOS.git",
    "directory": "packages/server/transformers/bot"
  },
  "author": "elbwalker <hello@elbwalker.com>",
  "homepage": "https://github.com/elbwalker/walkerOS#readme",
  "bugs": {
    "url": "https://github.com/elbwalker/walkerOS/issues"
  },
  "walkerOS": {
    "type": "transformer",
    "platform": [
      "server"
    ],
    "docs": "https://www.walkeros.io/docs/transformers/bot"
  },
  "keywords": [
    "walkerOS",
    "walkerOS-transformer",
    "transformer",
    "bot",
    "bot-detection",
    "ai-agent"
  ],
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/elbwalker"
    }
  ]
}
