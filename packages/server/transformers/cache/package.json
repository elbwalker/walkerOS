{
  "name": "@walkeros/server-transformer-cache",
  "description": "Cache transformer for walkerOS server - HTTP response caching with LRU eviction and per-rule TTL",
  "version": "3.0.1",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup --silent",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "jest --watchAll --colors",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.ts*\"",
    "test": "jest",
    "update": "npx npm-check-updates -u && npm update"
  },
  "devDependencies": {
    "@walkeros/core": "^3.0.1"
  },
  "dependencies": {
    "@walkeros/core": "^3.0.1",
    "@walkeros/store-memory": "^3.0.1"
  },
  "repository": {
    "url": "git+https://github.com/elbwalker/walkerOS.git",
    "directory": "packages/server/transformers/cache"
  },
  "author": "elbwalker <hello@elbwalker.com>",
  "homepage": "https://github.com/elbwalker/walkerOS#readme",
  "bugs": {
    "url": "https://github.com/elbwalker/walkerOS/issues"
  },
  "walkerOS": {
    "type": "transformer",
    "platform": "server",
    "docs": "https://www.walkeros.io/docs/transformers/cache"
  },
  "keywords": [
    "walkerOS",
    "transformer",
    "cache",
    "server"
  ],
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/elbwalker"
    }
  ]
}
