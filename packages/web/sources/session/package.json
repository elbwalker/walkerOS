{
  "name": "@walkeros/web-source-session",
  "description": "Session source for walkerOS",
  "version": "3.0.2",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.mjs",
      "require": "./dist/dev.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup --silent",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "jest --watchAll --colors",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.ts*\"",
    "test": "jest",
    "update": "npx npm-check-updates -u && npm update"
  },
  "dependencies": {
    "@walkeros/core": "^3.0.2",
    "@walkeros/web-core": "^3.0.2"
  },
  "devDependencies": {
    "@walkeros/collector": "^3.0.2"
  },
  "repository": {
    "url": "git+https://github.com/elbwalker/walkerOS.git",
    "directory": "packages/web/sources/session"
  },
  "author": "elbwalker <hello@elbwalker.com>",
  "homepage": "https://github.com/elbwalker/walkerOS#readme",
  "bugs": {
    "url": "https://github.com/elbwalker/walkerOS/issues"
  },
  "walkerOS": {
    "type": "source",
    "platform": [
      "web"
    ],
    "renderer": "codebox",
    "docs": "https://www.walkeros.io/docs/sources/web/session/detection"
  },
  "keywords": [
    "walkerOS",
    "walkerOS-source",
    "source",
    "web",
    "session",
    "analytics"
  ]
}
