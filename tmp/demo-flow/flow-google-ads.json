{
  "version": 1,
  "flows": {
    "default": {
      "web": {
        "windowCollector": "collector",
        "windowElb": "elb"
      },
      "packages": {
        "@walkeros/collector": {},
        "@walkeros/source-demo": {},
        "@walkeros/web-destination-gtag": {}
      },
      "sources": {
        "demo": {
          "package": "@walkeros/source-demo",
          "primary": true,
          "config": {
            "settings": {
              "events": [
                {
                  "name": "user sign_up",
                  "data": {
                    "plan": "pro",
                    "plan_value": 49.0,
                    "method": "email"
                  },
                  "delay": 0
                }
              ]
            }
          }
        }
      },
      "destinations": {
        "googleAds": {
          "package": "@walkeros/web-destination-gtag",
          "config": {
            "consent": {
              "marketing": true
            },
            "settings": {
              "ads": {
                "conversionId": "AW-123456789",
                "currency": "EUR"
              }
            },
            "mapping": {
              "user": {
                "sign_up": {
                  "name": "SIGNUP_CONVERSION",
                  "data": {
                    "map": {
                      "value": "data.plan_value"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "collector": {
        "run": true,
        "consent": {
          "marketing": true
        },
        "globals": {
          "environment": "demo",
          "version": "1.0.0"
        }
      }
    }
  }
}
