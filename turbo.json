{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "website/.env"],
  "concurrency": "2",
  "remoteCache": {
    "enabled": true,
    "signature": false
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"],
      "env": ["CI", "RSPACK_PROGRESS", "DOCUSAURUS_BASEURL"]
    },
    "build:website": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputLogs": "errors-only"
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "test": {
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "test:integration": {
      "dependsOn": ["build"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "update": {}
  }
}
