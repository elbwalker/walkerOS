{
  "$schema": "https://turbo.build/schema.json",
  "//": "concurrency: 4 with per-task memory bounds (jest workerIdleMemoryLimit) instead of a global throttle; keep the heavy website/docusaurus build out of inner-loop filters. Do not exceed 4 without re-running the memory probe (docs/plans/2026-05-22-test-perf-optimization.md). dependsOn: ['^build'] on typecheck/lint is intentional and kept: it preserves strict per-package typecheck (each package checks against upstream compiled .d.ts under its own lib/target), which a single-program source-based typecheck would lose. Cold-run speed comes from the remote cache + concurrency, not from weakening typecheck. See /workspaces/developer/AGENT.md rule 11.",
  "globalDependencies": ["**/.env.*local", "website/.env"],
  "concurrency": "4",
  "remoteCache": {
    "enabled": true,
    "signature": false
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"],
      "env": ["CI", "RSPACK_PROGRESS", "DOCUSAURUS_BASEURL"]
    },
    "build:website": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputLogs": "errors-only"
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.json",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.mjs",
        "eslint.config.*",
        ".eslintrc*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "test": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.json",
        "src/**/*.snap",
        "src/**/__fixtures__/**",
        "jest.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "test:integration": {
      "dependsOn": ["build"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "update": {}
  }
}
